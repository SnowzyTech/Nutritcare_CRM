model JournalEntryRow {
  id             String       @id @default(cuid())
  journalEntryId String
  account        String
  debits         Decimal      @default(0) @db.Decimal(10, 2)
  credits        Decimal      @default(0) @db.Decimal(10, 2)
  description    String?
  name           String?
  tax            Decimal      @default(0) @db.Decimal(10, 2)
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  @@index([journalEntryId])
  @@map("journal_entry_rows")
}

model FixedAsset {
  id                       String    @id @default(cuid())
  assetName                String
  description              String?
  nonDepreciable           Boolean   @default(false)
  purchasePrice            Decimal   @db.Decimal(10, 2)
  purchaseDate             DateTime
  // Depreciation parameters (null when nonDepreciable)
  depreciationStartDate    DateTime?
  depreciationMethod       String? // "Straight Line" | "Declining Balance" | "Sum of Years"
  usefulLifeYears          Int?
  salvageValue             Decimal   @default(0) @db.Decimal(10, 2)
  // Chart-of-Accounts mappings (account name + code snapshot)
  assetAccount             String
  assetAccountCode         String?
  accumDepreciationAccount String?
  accumDepreciationCode    String?
  depExpenseAccount        String?
  depExpenseCode           String?
  // Lifecycle
  status                   String    @default("Active") // Active | Disposed | Idle
  disposedAt               DateTime?
  createdById              String
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  deletedAt                DateTime?
  createdBy                User      @relation("FixedAssetCreatedBy", fields: [createdById], references: [id])

  @@index([createdById])
  @@index([status])
  @@index([deletedAt])
  @@map("fixed_assets")
}

// ----- Chat -----

model Conversation {
  id                 String               @id @default(cuid())
  type               ConversationType     @default(AGENT_GROUP)
  agentId            String?              @unique // set for AGENT_GROUP
  title              String? // denormalized agent companyName
  isArchived         Boolean              @default(false)
  // denormalized "last message" for a zero-scan conversation list:
  lastMessageAt      DateTime?
  lastMessagePreview String?
  lastMessageSender  String? // sender display name
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  agent              Agent?               @relation(fields: [agentId], references: [id])
  members            ConversationMember[]
  messages           Message[]

  @@index([lastMessageAt])
  @@map("conversations")
}

model ConversationMember {
  id               String       @id @default(cuid())
  conversationId   String
  userId           String
  // unread tracking — denormalized so the list + badges are O(1):
  unreadCount      Int          @default(0)
  hasUnreadMention Boolean      @default(false) // drives the "@" flag in the list
  lastReadAt       DateTime?
  mutedUntil       DateTime?
  joinedAt         DateTime     @default(now())
  conversation     Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_members")
}

model Message {
  id             String            @id @default(cuid())
  conversationId String
  senderId       String? // null = SYSTEM message
  type           MessageType       @default(TEXT)
  body           String // text w/ inline tokens
  imageUrl       String? // Cloudinary secure_url for IMAGE
  replyToId      String? // self-relation for quote/reply
  // denormalized reply preview to avoid N+1 on render:
  replyPreview   String?
  replySender    String?
  editedAt       DateTime?
  deletedAt      DateTime?
  createdAt      DateTime          @default(now())
  conversation   Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User?             @relation("MessageSender", fields: [senderId], references: [id])
  replyTo        Message?          @relation("MessageReplies", fields: [replyToId], references: [id])
  replies        Message[]         @relation("MessageReplies")
  mentions       MessageMention[]
  orderRefs      MessageOrderRef[]

  @@index([conversationId, createdAt])
  @@map("messages")
}

model MessageMention {
  id             String   @id @default(cuid())
  messageId      String
  userId         String // mentioned user
  conversationId String // denormalized for fast "my mentions"
  createdAt      DateTime @default(now())
  message        Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId, conversationId])
  @@map("message_mentions")
}

model MessageOrderRef {
  id        String  @id @default(cuid())
  messageId String
  orderId   String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  order     Order   @relation(fields: [orderId], references: [id])

  @@unique([messageId, orderId])
  @@index([orderId])
  @@map("message_order_refs")
}

