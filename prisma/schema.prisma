  company             String?
  name                String
  department          String?
  designation         String?
  level               String?
  amount              Decimal  @default(0) @db.Decimal(10, 2)
  basic               Decimal  @default(0) @db.Decimal(10, 2)
  housingAllowance    Decimal  @default(0) @db.Decimal(10, 2)
  grossPay            Decimal  @default(0) @db.Decimal(10, 2)
  transportation      Decimal  @default(0) @db.Decimal(10, 2)
  wardrobe            Decimal  @default(0) @db.Decimal(10, 2)
  utilityAllowance    Decimal  @default(0) @db.Decimal(10, 2)
  grossPayTotal       Decimal  @default(0) @db.Decimal(10, 2)
  paye                Decimal  @default(0) @db.Decimal(10, 2)
  pension             Decimal  @default(0) @db.Decimal(10, 2)
  hmo                 Decimal  @default(0) @db.Decimal(10, 2)
  otherDeduction      Decimal  @default(0) @db.Decimal(10, 2)
  netPay              Decimal  @default(0) @db.Decimal(10, 2)
  bank                Decimal  @default(0) @db.Decimal(10, 2)
  cash                Decimal  @default(0) @db.Decimal(10, 2)
  zenithAccountNumber String?
  remark              String?
  date                DateTime @default(now())
  createdById         String?
