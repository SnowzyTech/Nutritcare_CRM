generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                      String                  @id @default(cuid())
  name                    String
  email                   String                  @unique
  password                String
  role                    UserRole                @default(SALES_REP)
  phone                   String?
  whatsappNumber          String?
  avatarUrl               String?
  isActive                Boolean                 @default(true)
  teamId                  String?
  isTeamLead              Boolean                 @default(false)
  accountActivationStatus AccountActivationStatus @default(PENDING)
  agentId                 String?                 @unique
  warehouseId             String?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  agentsAdded             Agent[]                 @relation("AgentAddedBy")
  auditLogs               AuditLog[]              @relation("UserAuditLogs")
  conversationMembers     ConversationMember[]
  sentMessages            Message[]               @relation("MessageSender")
  mentions                MessageMention[]
  damageReports           DamageReport[]          @relation("DamageReportedBy")
  deliveries              Delivery[]              @relation("DriverDeliveries")
  driversAdded            Driver[]                @relation("DriverAddedBy")
  expenses                Expense[]               @relation("ExpenseCreatedBy")
  fixedAssets             FixedAsset[]            @relation("FixedAssetCreatedBy")
  forms                   Form[]                  @relation("FormCreatedBy")
  invoices                Invoice[]               @relation("InvoiceCreatedBy")
  journalEntries          JournalEntry[]          @relation("JournalEntryCreator")
  notifications           Notification[]          @relation("UserNotifications")
  upsoldOrderItems        OrderItem[]             @relation("UpsoldOrderItems")
  orders                  Order[]                 @relation("SalesRepOrders")
  discountedOrders        Order[]                 @relation("DiscountedOrders")
  pickPackAssignments     PickPack[]              @relation("PickerAssignments")
  purchaseOrders          PurchaseOrder[]         @relation("PurchaseOrderCreatedBy")
  salaryRecords           SalaryRecord[]          @relation("SalaryCreatedBy")
  settlementAdjustments   SettlementAdjustment[]  @relation("AdjustmentCreatedBy")
  stockAdjustments        StockAdjustment[]       @relation("StockAdjustmentCreatedBy")
  stockMovements          StockMovement[]         @relation("StockMovementCreatedBy")
  stockTransfers          StockTransfer[]         @relation("StockTransferCreatedBy")
  agent                   Agent?                  @relation("UserAgent", fields: [agentId], references: [id])
  team                    Team?                   @relation(fields: [teamId], references: [id])
  warehouse               Warehouse?              @relation("WarehouseManagers", fields: [warehouseId], references: [id])

  @@index([email])
  @@index([role])
  @@index([teamId])
  @@index([warehouseId])
  @@index([accountActivationStatus])
  @@map("users")
}

model Team {
  id         String     @id @default(cuid())
  name       String
  department Department
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  members    User[]

  @@index([department])
  @@map("teams")
}

model Customer {
  id              String    @id @default(cuid())
  name            String
  phone           String
  whatsappNumber  String?
  email           String?
  deliveryAddress String
  state           String
  lga             String
  landmark        String?
  source          String?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  invoices        Invoice[]
  orders          Order[]

  @@index([email])
  @@index([state])
  @@map("customers")
}

model ProductCategory {
  id                  String    @id @default(cuid())
  categoryName        String
  brandName           String
  brandPhone          String?
  brandWhatsappNumber String?
  brandEmail          String?
  smsSenderId         String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?
  products            Product[]

  @@map("product_categories")
}

model Product {
  id                    String                @id @default(cuid())
  name                  String
  description           String?
  costPrice             Decimal               @db.Decimal(10, 2)
  sellingPrice          Decimal               @db.Decimal(10, 2)
  categoryId            String
  country               String?
  hasVariations         Boolean               @default(false)
  hasOffer              Boolean               @default(false)
  displayText           String?
  fileDownloadLink      String?
  lowStockAlertQtyAgent Int?
  lowStockAlertQtyTotal Int?
  alertEmails           String?
  sku                   String                @unique
  isActive              Boolean               @default(true)
  deletedAt             DateTime?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  imageUrl              String?
  quantity              Int                   @default(0)
  unit                  String?
  invoiceItems          InvoiceItem[]
  orderItems            OrderItem[]
  comboOf               ProductCombo[]        @relation("ComboProduct")
  combos                ProductCombo[]        @relation("ParentProductCombos")
  giftOf                ProductGift[]         @relation("GiftProduct")
  gifts                 ProductGift[]         @relation("ParentProductGifts")
  offers                ProductOffer[]
  packages              ProductPackage[]
  category              ProductCategory       @relation(fields: [categoryId], references: [id])
  purchaseOrderItems    PurchaseOrderItem[]
  shelfProductStocks    ShelfProductStock[]
  stockAdjustmentItems  StockAdjustmentItem[]
  stockLevels           StockLevel[]
  stockMovementItems    StockMovementItem[]
  stockTransferItems    StockTransferItem[]

  @@index([categoryId])
  @@index([sku])
  @@index([isActive])
  @@map("products")
}

model StockLevel {
  id           String   @id @default(cuid())
  productId    String
  locationKind String
  locationId   String
  quantity     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, locationKind, locationId])
  @@index([productId])
  @@index([locationKind, locationId])
  @@map("stock_levels")
}

model ProductOffer {
  id                  String   @id @default(cuid())
  productId           String
  offerName           String
  offerQuantity       Int
  offerUnit           String
  recurring           String?
  sellingPrice        Decimal  @db.Decimal(10, 2)
  showQuantityAndUnit Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  product             Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_offers")
}

model ProductPackage {
  id        String   @id @default(cuid())
  productId String
  name      String
  quantity  Int      @default(0)
  price     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_packages")
}

model ProductCombo {
  id             String   @id @default(cuid())
  productId      String
  comboProductId String
  quantity       Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  comboProduct   Product  @relation("ComboProduct", fields: [comboProductId], references: [id])
  product        Product  @relation("ParentProductCombos", fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([comboProductId])
  @@map("product_combos")
}

model ProductGift {
  id            String   @id @default(cuid())
  productId     String
  giftProductId String
  quantity      Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  giftProduct   Product  @relation("GiftProduct", fields: [giftProductId], references: [id])
  product       Product  @relation("ParentProductGifts", fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([giftProductId])
  @@map("product_gifts")
}

model Supplier {
  id              String           @id @default(cuid())
  name            String
  phone1          String           @unique
  phone2          String?
  state           String?
  address         String?
  country         String?
  payableBalance  Decimal          @default(0) @db.Decimal(10, 2)
  deletedAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  expenses        Expense[]        @relation("ExpenseSupplier")
  goodsReceivings GoodsReceiving[]
  purchaseOrders  PurchaseOrder[]
  stockMovements  StockMovement[]

  @@map("suppliers")
}

model Agent {
  id                    String                 @id @default(cuid())
  companyName           String
  state                 String?
  address               String?
  phone1                String                 @unique
  phone2                String?
  phone3                String?
  status                AgentStatus            @default(ACTIVE)
  statesCovered         Json?
  picksFromOfficeStock  Boolean                @default(false)
  country               String?
  vehicleNo             String?
  reviewStatus          String?
  addedById             String
  deletedAt             DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  deliveryFee           Decimal?               @db.Decimal(10, 2)
  agentLedgerEntries    AgentLedgerEntry[]
  agentSettlements      AgentSettlement[]
  addedBy               User                   @relation("AgentAddedBy", fields: [addedById], references: [id])
  deliveries            Delivery[]             @relation("AgentDeliveries")
  orders                Order[]
  settlementAdjustments SettlementAdjustment[]
  stockMovementsFrom    StockMovement[]        @relation("StockMovementAgent")
  stockMovementsDriver  StockMovement[]        @relation("StockMovementDriver")
  stockMovementsTo      StockMovement[]        @relation("StockMovementToAgent")
  stockTransfersDriver  StockTransfer[]        @relation("StockTransferDriver")
  user                  User?                  @relation("UserAgent")
  conversation          Conversation?

  @@index([status])
  @@index([addedById])
  @@map("agents")
}

model Driver {
  id             String          @id @default(cuid())
  name           String
  phone1         String          @unique
  phone2         String?
  phone3         String?
  address        String?
  state          String?
  country        String?
  vehicleNo      String?
  status         AgentStatus     @default(ACTIVE)
  addedById      String
  deletedAt      DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deliveries     Delivery[]      @relation("TruckDriverDeliveries")
  addedBy        User            @relation("DriverAddedBy", fields: [addedById], references: [id])
  stockMovements StockMovement[] @relation("StockMovementDriverEntity")
  stockTransfers StockTransfer[] @relation("StockTransferDriverEntity")

  @@index([status])
  @@index([addedById])
  @@map("drivers")
}

model Warehouse {
  id               String              @id @default(cuid())
  name             String
  address          String?
  phone            String?
  email            String?
  country          String?
  additionalInfo   String?
  managerName      String?
  managerPhone     String?
  managerEmail     String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  deletedAt        DateTime?
  referenceCode    String?             @unique
  stockAdjustments StockAdjustment[]
  stockMovements   StockMovement[]
  managers         User[]              @relation("WarehouseManagers")
  locations        WarehouseLocation[]

  @@map("warehouses")
}

model WarehouseLocation {
  id                   String                @id @default(cuid())
  warehouseId          String
  locationCode         String
  occupancyStatus      OccupancyStatus       @default(EMPTY)
  zone                 String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  currentStock         Int                   @default(0)
  maxCapacity          Int?
  fullThreshold        Int?
  partialThreshold     Int?
  emptyThreshold       Int?
  damageReports        DamageReport[]
  shelfProductStocks   ShelfProductStock[]
  stockAdjustmentItems StockAdjustmentItem[]
  stockMovements       StockMovement[]       @relation("StockMovementShelfLocation")
  warehouse            Warehouse             @relation(fields: [warehouseId], references: [id])

  @@index([warehouseId])
  @@index([occupancyStatus])
  @@map("warehouse_locations")
}

model ShelfProductStock {
  id         String            @id @default(cuid())
  locationId String
  productId  String
  quantity   Int               @default(0)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  location   WarehouseLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  product    Product           @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([locationId, productId])
  @@index([locationId])
  @@index([productId])
  @@map("shelf_product_stocks")
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  customerId      String
  salesRepId      String
  agentId          String?
  status           OrderStatus      @default(PENDING)
  remittanceStatus RemittanceStatus @default(NOT_REMITTED)
  totalAmount     Decimal     @db.Decimal(10, 2)
  discountAmount  Decimal     @default(0) @db.Decimal(10, 2)
  discountPercent Decimal     @default(0) @db.Decimal(5, 2)
  netAmount       Decimal     @db.Decimal(10, 2)
  deliveryFee     Decimal     @default(0) @db.Decimal(10, 2)
  notes           String?
  date            DateTime    @default(now())
  deletedAt       DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  isReorder       Boolean     @default(false)
  discountedById  String?
  discountReason  String?
  discountedAt    DateTime?
  contactMethod      ContactMethod?
  cancellationReason String?
  deliveries      Delivery[]
  invoices        Invoice[]
  items           OrderItem[]
  agent           Agent?      @relation(fields: [agentId], references: [id])
  customer        Customer    @relation(fields: [customerId], references: [id])
  salesRep        User        @relation("SalesRepOrders", fields: [salesRepId], references: [id])
  discountedBy    User?       @relation("DiscountedOrders", fields: [discountedById], references: [id])
  pickPacks       PickPack[]
  messageRefs     MessageOrderRef[]

  @@index([customerId])
  @@index([salesRepId])
  @@index([agentId])
  @@index([status])
  @@index([remittanceStatus])
  @@index([orderNumber])
  @@index([createdAt])
  @@index([discountedById])
  @@map("orders")
}

model OrderItem {
  id              String   @id @default(cuid())
  orderId         String
  productId       String
  quantity        Int
  unitPrice       Decimal  @db.Decimal(10, 2)
  lineTotal       Decimal  @db.Decimal(10, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  costPriceAtSale Decimal  @default(0) @db.Decimal(10, 2)
  addedById       String?
  isUpsell        Boolean  @default(false)
  addedBy         User?    @relation("UpsoldOrderItems", fields: [addedById], references: [id])
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product  @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@index([addedById])
  @@map("order_items")
}

model StockMovement {
  id                     String              @id @default(cuid())
  referenceNumber        String              @unique
  type                   StockMovementType
  status                 StockMovementStatus @default(DRAFT)
  warehouseId            String?
  supplierId             String?
  agentId                String?
  supplierReference      String?
  date                   DateTime
  notes                  String?
  state                  String?
  country                String?
  damaged                Boolean?
  remarks                String?
  quantity               Int?
  quantitySent           Int?
  isAgentToAgentTransfer Boolean?            @default(false)
  toAgentId              String?
  driverAgentId          String?
  scheduledTime          DateTime?
  createdById            String
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  isDamaged              Boolean             @default(false)
  isReserved             Boolean             @default(false)
  shelfAssignments       Json?
  shelfLocationId        String?
  shelfQuantity          Int?
  driverId               String?
  goodsReceivings        GoodsReceiving[]
  pickPacks              PickPack[]          @relation("PickPackStockMovement")
  items                  StockMovementItem[]
  agent                  Agent?              @relation("StockMovementAgent", fields: [agentId], references: [id])
  createdBy              User                @relation("StockMovementCreatedBy", fields: [createdById], references: [id])
  driverAgent            Agent?              @relation("StockMovementDriver", fields: [driverAgentId], references: [id])
  driver                 Driver?             @relation("StockMovementDriverEntity", fields: [driverId], references: [id])
  shelfLocation          WarehouseLocation?  @relation("StockMovementShelfLocation", fields: [shelfLocationId], references: [id])
  supplier               Supplier?           @relation(fields: [supplierId], references: [id])
  toAgent                Agent?              @relation("StockMovementToAgent", fields: [toAgentId], references: [id])
  warehouse              Warehouse?          @relation(fields: [warehouseId], references: [id])

  @@index([type])
  @@index([status])
  @@index([warehouseId])
  @@index([supplierId])
  @@index([agentId])
  @@index([driverId])
  @@index([createdById])
  @@index([referenceNumber])
  @@index([createdAt])
  @@index([shelfLocationId])
  @@map("stock_movements")
}

model StockMovementItem {
  id              String        @id @default(cuid())
  stockMovementId String
  productId       String
  productCode     String
  quantity        Int
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  product         Product       @relation(fields: [productId], references: [id])
  stockMovement   StockMovement @relation(fields: [stockMovementId], references: [id], onDelete: Cascade)

  @@index([stockMovementId])
  @@index([productId])
  @@map("stock_movement_items")
}

model StockTransfer {
  id              String                @id @default(cuid())
  referenceNumber String                @unique
  sourceType      StockTransferNodeType
  sourceId        String
  targetType      StockTransferNodeType
  targetId        String
  date            DateTime
  status          StockTransferStatus   @default(DRAFT)
  notes           String?
  driverAgentId   String?
  scheduledTime   DateTime?
  createdById     String
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  driverId        String?
  pickPacks       PickPack[]            @relation("PickPackStockTransfer")
  items           StockTransferItem[]
  createdBy       User                  @relation("StockTransferCreatedBy", fields: [createdById], references: [id])
  driverAgent     Agent?                @relation("StockTransferDriver", fields: [driverAgentId], references: [id])
  driver          Driver?               @relation("StockTransferDriverEntity", fields: [driverId], references: [id])

  @@index([status])
  @@index([driverId])
  @@index([createdById])
  @@index([referenceNumber])
  @@map("stock_transfers")
}

model StockTransferItem {
  id              String        @id @default(cuid())
  stockTransferId String
  productId       String
  quantity        Int
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  product         Product       @relation(fields: [productId], references: [id])
  stockTransfer   StockTransfer @relation(fields: [stockTransferId], references: [id], onDelete: Cascade)

  @@index([stockTransferId])
  @@index([productId])
  @@map("stock_transfer_items")
}

model PurchaseOrder {
  id          String              @id @default(cuid())
  poNumber    String              @unique
  supplierId  String
  status      PurchaseOrderStatus @default(PENDING)
  date        DateTime            @default(now())
  createdById String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  items       PurchaseOrderItem[]
  createdBy   User                @relation("PurchaseOrderCreatedBy", fields: [createdById], references: [id])
  supplier    Supplier            @relation(fields: [supplierId], references: [id])

  @@index([supplierId])
  @@index([status])
  @@index([createdById])
  @@index([poNumber])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  productId       String
  quantity        Int
  unitCost        Decimal       @db.Decimal(10, 2)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  product         Product       @relation(fields: [productId], references: [id])
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@index([productId])
  @@map("purchase_order_items")
}

model PickPack {
  id              String         @id @default(cuid())
  orderId         String?
  pickerId        String?
  locationCode    String         @default("")
  itemsCount      Int
  status          PickPackStatus @default(QUEUED)
  assignedAt      DateTime?
  completedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  stockMovementId String?
  stockTransferId String?
  packerId        String?
  order           Order?         @relation(fields: [orderId], references: [id])
  packer          PickPacker?    @relation(fields: [packerId], references: [id])
  picker          User?          @relation("PickerAssignments", fields: [pickerId], references: [id])
  stockMovement   StockMovement? @relation("PickPackStockMovement", fields: [stockMovementId], references: [id])
  stockTransfer   StockTransfer? @relation("PickPackStockTransfer", fields: [stockTransferId], references: [id])

  @@index([orderId])
  @@index([stockMovementId])
  @@index([stockTransferId])
  @@index([pickerId])
  @@index([packerId])
  @@index([status])
  @@map("pick_packs")
}

model PickPacker {
  id          String     @id @default(cuid())
  name        String
  warehouseId String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  pickPacks   PickPack[]

  @@index([warehouseId])
  @@map("pick_packers")
}

model GoodsReceiving {
  id              String         @id @default(cuid())
  stockMovementId String
  incId           String         @unique
  units           Int
  supplierId      String
  qcStatus        QCStatus       @default(PENDING)
  shelvingStatus  ShelvingStatus @default(QC_CHECK)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  stockMovement   StockMovement  @relation(fields: [stockMovementId], references: [id])
  supplier        Supplier       @relation(fields: [supplierId], references: [id])

  @@index([stockMovementId])
  @@index([supplierId])
  @@index([qcStatus])
  @@map("goods_receivings")
}

model Delivery {
  id            String         @id @default(cuid())
  orderId       String
  driverId      String?
  agentId       String?
  vehicleId     String?
  status        DeliveryStatus @default(PENDING_DISPATCH)
  scheduledTime DateTime?
  deliveredTime DateTime?
  zoneId        String?
  failureReason String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deliveryCode  String?
  truckDriverId String?
  agent         Agent?         @relation("AgentDeliveries", fields: [agentId], references: [id])
  driver        User?          @relation("DriverDeliveries", fields: [driverId], references: [id])
  order         Order          @relation(fields: [orderId], references: [id])
  truckDriver   Driver?        @relation("TruckDriverDeliveries", fields: [truckDriverId], references: [id])
  vehicle       Vehicle?       @relation(fields: [vehicleId], references: [id])
  zone          DeliveryZone?  @relation(fields: [zoneId], references: [id])

  @@index([orderId])
  @@index([driverId])
  @@index([agentId])
  @@index([truckDriverId])
  @@index([status])
  @@map("deliveries")
}

model Vehicle {
  id          String      @id @default(cuid())
  name        String
  type        VehicleType
  capacity    Int?
  isAvailable Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deliveries  Delivery[]

  @@index([type])
  @@map("vehicles")
}

model DeliveryZone {
  id           String     @id @default(cuid())
  name         String
  description  String?
  coverageArea String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deliveries   Delivery[]
  routes       Route[]

  @@map("delivery_zones")
}

model Route {
  id          String       @id @default(cuid())
  zoneId      String
  name        String
  stopsCount  Int
  distanceKm  Decimal      @db.Decimal(10, 2)
  optimizedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  zone        DeliveryZone @relation(fields: [zoneId], references: [id])

  @@index([zoneId])
  @@map("routes")
}

model DamageReport {
  id                  String             @id @default(cuid())
  warehouseLocationId String
  description         String
  status              DamageReportStatus @default(OPEN)
  reportedById        String
  resolvedAt          DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  reportedBy          User               @relation("DamageReportedBy", fields: [reportedById], references: [id])
  warehouseLocation   WarehouseLocation  @relation(fields: [warehouseLocationId], references: [id])

  @@index([warehouseLocationId])
  @@index([status])
  @@index([reportedById])
  @@map("damage_reports")
}

model Invoice {
  id              String        @id @default(cuid())
  invoiceNumber   String        @unique
  customerId      String
  orderId         String?
  terms           String?
  invoiceDate     DateTime
  dueDate         DateTime?
  subtotal        Decimal       @db.Decimal(10, 2)
  discountPercent Decimal       @default(0) @db.Decimal(5, 2)
  discountAmount  Decimal       @default(0) @db.Decimal(10, 2)
  shipping        Decimal       @default(0) @db.Decimal(10, 2)
  invoiceTotal    Decimal       @db.Decimal(10, 2)
  status          InvoiceStatus @default(DRAFT)
  attachmentUrl   String?
  showLogo        Boolean       @default(true)
  showShipTo      Boolean       @default(true)
  showInvoiceNo   Boolean       @default(true)
  showInvoiceDate Boolean       @default(true)
  showDueDate     Boolean       @default(true)
  showDiscount    Boolean       @default(true)
  showTerms       Boolean       @default(true)
  type            InvoiceType   @default(INVOICE)
  createdById     String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  items           InvoiceItem[]
  createdBy       User          @relation("InvoiceCreatedBy", fields: [createdById], references: [id])
  customer        Customer      @relation(fields: [customerId], references: [id])
  order           Order?        @relation(fields: [orderId], references: [id])

  @@index([customerId])
  @@index([orderId])
  @@index([status])
  @@index([invoiceNumber])
  @@index([createdById])
  @@map("invoices")
}

model InvoiceItem {
