model Expense {
  id                String            @id @default(cuid())
  referenceNumber   String            @unique
  expenseCategoryId String
  paidFromAccountId String
  date              DateTime
  amount            Decimal           @db.Decimal(10, 2)
  tax               Decimal           @default(0) @db.Decimal(10, 2)
  notes             String?
  attachmentUrl     String?
  createdById       String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  attachmentUrls    String[]          @default([])
  expenseNameId     String?
  supplierId        String?
  lineItems         ExpenseLineItem[]
  createdBy         User              @relation("ExpenseCreatedBy", fields: [createdById], references: [id])
  expenseCategory   ExpenseCategory   @relation(fields: [expenseCategoryId], references: [id])
  expenseName       ExpenseName?      @relation(fields: [expenseNameId], references: [id])
  paidFromAccount   PaymentAccount    @relation(fields: [paidFromAccountId], references: [id])
  supplier          Supplier?         @relation("ExpenseSupplier", fields: [supplierId], references: [id])

  @@index([expenseCategoryId])
  @@index([expenseNameId])
  @@index([supplierId])
  @@index([paidFromAccountId])
  @@index([createdById])
  @@index([referenceNumber])
  @@map("expenses")
